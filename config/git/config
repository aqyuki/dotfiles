[include]
  path = $XDG_CONFIG_HOME/git/gpg.ini

[user]
  name=aqyuki
  email=uwaaa@aqyuki.dev

[init]
  defaultBranch=main
  defaultRemote=origin
  defaultRemoteBranch=main

[commit]
  gpgsign=true

[core]
  editor=vim

[rebase]
    updateRefs = true
[fetch]
    prune = true
[status]
    showUntrackedFiles = all
