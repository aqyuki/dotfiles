command = /usr/bin/fish
shell-integration = fish
theme = Broadcast

clipboard-read = allow
clipboard-write = allow
confirm-close-surface = false
background-opacity = 0.9
unfocused-split-opacity = 0.95
cursor-opacity = 0.5
cursor-style = block
font-size = 10
font-family = HackGen35 Console NF

### Window config
gtk-titlebar = true
window-padding-balance = true
window-theme = ghostty
window-height = 40
window-width = 120

# key binds

## Ctrl + Shift + jはtmuxのショートカットと競合するため無効化
keybind = ctrl+shift+j=unbind
