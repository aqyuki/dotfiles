# XDG BASE DIRECTORY settings
export XDG_ROOT=$HOME/.xdg
export XDG_CONFIG_HOME=$XDG_ROOT/config
export XDG_CACHE_HOME=$XDG_ROOT/cache
export XDG_DATA_HOME=$XDG_ROOT/data
export XDG_STATE_HOME=$XDG_ROOT/state

# zsh setting
export DOTFILE_ROOT=$HOME/dotfiles
export DOTFILE_CONFIG=$DOTFILE_ROOT/config
export DOTFILE_ZSH_PLUGIN=$DOTFILE_ROOT/zsh/plugin

# language runtimes
export RUNTIME_ROOT=$HOME/.runtime

# Tool configs
export GHQ_ROOT=$HOME/repo

